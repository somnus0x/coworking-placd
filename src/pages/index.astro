---
import Base from '../layouts/Base.astro';
import SpotCard from '../components/SpotCard.astro';
import FilterBar from '../components/FilterBar.astro';
import MapView from '../components/MapView.astro';
import spots from '../data/spots.json';
import '../styles/global.css';

const featured = spots.filter(s => s.featured);
const rest = spots.filter(s => !s.featured);
const allSpots = [...featured, ...rest];
---

<Base>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <!-- Header -->
    <header class="mb-12">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-neutral-100 mb-3">
        placd<span class="text-accent">.</span>
      </h1>
      <p class="text-lg text-neutral-400 max-w-xl">
        Free places to work in Bangkok. Cafes, libraries, malls, hidden spots. No coworking fees. Just show up with a laptop.
      </p>
      <div class="flex gap-4 mt-4 text-sm text-muted">
        <span>{spots.length} spots</span>
        <span>·</span>
        <span>Curated, not scraped</span>
        <span>·</span>
        <span>Updated manually</span>
      </div>
    </header>

    <!-- View Toggle -->
    <div class="flex items-center gap-2 mb-6">
      <button
        id="view-list"
        class="view-toggle text-xs px-3 py-1.5 rounded-full border border-accent text-accent bg-accent/10 transition-all duration-150"
        data-view="list"
      >
        ☰ List
      </button>
      <button
        id="view-map"
        class="view-toggle text-xs px-3 py-1.5 rounded-full border border-border text-muted hover:border-neutral-600 hover:text-neutral-300 transition-all duration-150"
        data-view="map"
      >
        🗺 Map
      </button>

      <!-- Rating Legend (inline, list view only) -->
      <div id="rating-legend" class="ml-auto flex flex-wrap gap-3 text-[11px] text-muted">
        <span><span class="text-accent font-medium">WiFi</span> speed</span>
        <span><span class="text-accent font-medium">Power</span> outlets</span>
        <span><span class="text-accent font-medium">Quiet</span> noise</span>
        <span><span class="text-accent font-medium">Laptop</span> welcome</span>
      </div>
    </div>

    <!-- Filters -->
    <FilterBar />

    <!-- Map View -->
    <div id="map-view" class="hidden mb-8">
      <MapView />
      <!-- Map Legend -->
      <div class="flex flex-wrap gap-4 mt-3 text-xs text-muted">
        <span><span class="inline-block w-2.5 h-2.5 rounded-full bg-amber-500 mr-1"></span>Cafe</span>
        <span><span class="inline-block w-2.5 h-2.5 rounded-full bg-blue-500 mr-1"></span>Library</span>
        <span><span class="inline-block w-2.5 h-2.5 rounded-full bg-purple-500 mr-1"></span>Lifestyle</span>
        <span><span class="inline-block w-2.5 h-2.5 rounded-full bg-green-500 mr-1"></span>Free Coworking</span>
        <span><span class="inline-block w-2.5 h-2.5 rounded-full bg-red-500 opacity-40 mr-1"></span>Closed</span>
        <span class="text-neutral-600">|</span>
        <span><span class="inline-block w-4 border-t-2 border-dashed mr-1" style="border-color:#5cb85c;"></span>BTS</span>
        <span><span class="inline-block w-4 border-t-2 border-dashed mr-1" style="border-color:#1e5ba0;"></span>MRT</span>
      </div>
    </div>

    <!-- Spots Grid (List View) -->
    <div class="grid gap-4" id="spots-grid">
      {allSpots.map(spot => (
        <div data-area={spot.area} data-type={spot.type}>
          <SpotCard spot={spot} />
        </div>
      ))}
    </div>

    <!-- Footer -->
    <footer class="mt-16 pt-8 border-t border-border text-center">
      <p class="text-sm text-muted">
        Know a spot? <a href="https://github.com/somnus0x/coworking-placd" class="text-accent hover:underline">Open a PR</a> or DM.
      </p>
      <p class="text-xs text-neutral-600 mt-2">
        Built in Bangkok. Not affiliated with any venue.
      </p>
    </footer>
  </div>
</Base>

<script>
  const listBtn = document.getElementById('view-list')!;
  const mapBtn = document.getElementById('view-map')!;
  const spotsGrid = document.getElementById('spots-grid')!;
  const mapView = document.getElementById('map-view')!;
  const ratingLegend = document.getElementById('rating-legend')!;

  function setView(view: string) {
    if (view === 'map') {
      spotsGrid.classList.add('hidden');
      mapView.classList.remove('hidden');
      ratingLegend.classList.add('hidden');
      mapBtn.classList.remove('border-border', 'text-muted');
      mapBtn.classList.add('border-accent', 'text-accent', 'bg-accent/10');
      listBtn.classList.remove('border-accent', 'text-accent', 'bg-accent/10');
      listBtn.classList.add('border-border', 'text-muted');
      // Init map on first show, invalidate on subsequent shows
      setTimeout(() => {
        if (!(window as any)._placdMapReady && (window as any)._placdMapInit) {
          (window as any)._placdMapInit();
          (window as any)._placdMapReady = true;
        } else if ((window as any)._placdMap) {
          (window as any)._placdMap.invalidateSize();
        }
      }, 50);
    } else {
      spotsGrid.classList.remove('hidden');
      mapView.classList.add('hidden');
      ratingLegend.classList.remove('hidden');
      listBtn.classList.remove('border-border', 'text-muted');
      listBtn.classList.add('border-accent', 'text-accent', 'bg-accent/10');
      mapBtn.classList.remove('border-accent', 'text-accent', 'bg-accent/10');
      mapBtn.classList.add('border-border', 'text-muted');
    }
  }

  listBtn.addEventListener('click', () => setView('list'));
  mapBtn.addEventListener('click', () => setView('map'));
</script>
