---
const areas = ['All', 'Ploenchit', 'Siam', 'Riverside', 'Charoenkrung', 'Sam Yan', 'Thonglor', 'Ekkamai', 'Silom', 'Ratchathewi'];
const types = ['All', 'cafe', 'library', 'lifestyle-space', 'free-coworking'];
const typeLabels: Record<string, string> = {
  'All': 'All Types',
  'cafe': '☕ Cafe',
  'library': '📚 Library',
  'lifestyle-space': '✨ Lifestyle',
  'free-coworking': '💻 Free',
};
---

<div class="flex flex-wrap gap-2 mb-8" id="filter-bar">
  <div class="w-full flex flex-wrap gap-2 mb-2">
    <span class="text-xs text-muted self-center mr-1">Area:</span>
    {areas.map(area => (
      <button
        data-filter="area"
        data-value={area}
        class:list={[
          "filter-btn text-xs px-3 py-1.5 rounded-full border transition-all duration-150",
          area === 'All'
            ? "border-accent text-accent bg-accent/10"
            : "border-border text-muted hover:border-neutral-600 hover:text-neutral-300"
        ]}
      >
        {area}
      </button>
    ))}
  </div>
  <div class="w-full flex flex-wrap gap-2">
    <span class="text-xs text-muted self-center mr-1">Type:</span>
    {types.map(type => (
      <button
        data-filter="type"
        data-value={type}
        class:list={[
          "filter-btn text-xs px-3 py-1.5 rounded-full border transition-all duration-150",
          type === 'All'
            ? "border-accent text-accent bg-accent/10"
            : "border-border text-muted hover:border-neutral-600 hover:text-neutral-300"
        ]}
      >
        {typeLabels[type]}
      </button>
    ))}
  </div>
</div>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('[data-area]');
  let activeArea = 'All';
  let activeType = 'All';

  function applyFilters() {
    cards.forEach(card => {
      const el = card as HTMLElement;
      const matchArea = activeArea === 'All' || el.dataset.area === activeArea;
      const matchType = activeType === 'All' || el.dataset.type === activeType;
      el.style.display = matchArea && matchType ? '' : 'none';
    });
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const filterType = el.dataset.filter!;
      const value = el.dataset.value!;

      if (filterType === 'area') activeArea = value;
      if (filterType === 'type') activeType = value;

      document.querySelectorAll(`[data-filter="${filterType}"]`).forEach(b => {
        b.classList.remove('border-accent', 'text-accent', 'bg-accent/10');
        b.classList.add('border-border', 'text-muted');
      });
      el.classList.remove('border-border', 'text-muted');
      el.classList.add('border-accent', 'text-accent', 'bg-accent/10');

      applyFilters();

      // Store current filter state for lazy map init replay
      (window as any)._placdFilterState = { area: activeArea, type: activeType };

      // Notify map view of filter change
      window.dispatchEvent(new CustomEvent('placd:filter', {
        detail: { area: activeArea, type: activeType }
      }));
    });
  });
</script>
