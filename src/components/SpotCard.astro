---
import RatingDots from './RatingDots.astro';

interface Props {
  spot: {
    id: string;
    name: string;
    subtitle: string;
    area: string;
    nearest_bts: string | null;
    nearest_mrt: string | null;
    type: string;
    tags: string[];
    wifi: number;
    power: number;
    noise: number;
    laptop_friendly: number;
    cost: string;
    best_hours: string;
    description: string;
    tips: string;
    google_maps: string;
    featured?: boolean;
  };
}

const { spot } = Astro.props;

const typeLabels: Record<string, string> = {
  'cafe': '☕ Cafe',
  'library': '📚 Library',
  'lifestyle-space': '✨ Lifestyle Space',
  'free-coworking': '💻 Free Coworking',
};

const transit = [
  spot.nearest_bts && `BTS ${spot.nearest_bts}`,
  spot.nearest_mrt && `MRT ${spot.nearest_mrt}`,
].filter(Boolean).join(' · ');
---

<article
  id={spot.id}
  class:list={[
    "group rounded-xl border p-5 transition-all duration-200",
    spot.featured
      ? "border-accent/30 bg-surface-raised hover:border-accent/50"
      : "border-border bg-surface-raised hover:border-neutral-700"
  ]}
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <div>
      <h3 class="font-display text-lg font-semibold text-neutral-100 group-hover:text-accent transition-colors">
        {spot.name}
      </h3>
      <p class="text-sm text-muted">{spot.subtitle}</p>
    </div>
    {spot.featured && (
      <span class="shrink-0 text-xs font-medium bg-accent/10 text-accent px-2 py-1 rounded-full">
        pick
      </span>
    )}
  </div>

  <div class="flex flex-wrap gap-2 mb-3 text-xs">
    <span class="bg-surface-overlay text-neutral-300 px-2 py-0.5 rounded">
      {typeLabels[spot.type] || spot.type}
    </span>
    <span class="bg-surface-overlay text-neutral-300 px-2 py-0.5 rounded">
      {spot.area}
    </span>
    {transit && (
      <span class="bg-surface-overlay text-neutral-400 px-2 py-0.5 rounded">
        {transit}
      </span>
    )}
  </div>

  <p class="text-sm text-neutral-300 leading-relaxed mb-4">
    {spot.description}
  </p>

  <div class="grid grid-cols-2 gap-2 mb-4">
    <RatingDots value={spot.wifi} label="WiFi" />
    <RatingDots value={spot.power} label="Power" />
    <RatingDots value={spot.noise} label="Quiet" max={5} />
    <RatingDots value={spot.laptop_friendly} label="Laptop" />
  </div>

  <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-muted mb-3">
    <span>💰 {spot.cost}</span>
    <span>🕐 {spot.best_hours}</span>
  </div>

  {spot.tips && (
    <div class="text-xs text-neutral-400 bg-surface-overlay rounded-lg p-3 mb-3">
      <span class="text-accent font-medium">Tip:</span> {spot.tips}
    </div>
  )}

  <div class="flex gap-2">
    {spot.tags.map(tag => (
      <span class="text-[10px] text-muted bg-surface px-1.5 py-0.5 rounded">
        #{tag}
      </span>
    ))}
  </div>
</article>
